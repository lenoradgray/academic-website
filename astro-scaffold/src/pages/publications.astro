---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';

const pubs = await getCollection('publications');
const sorted = pubs.sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order
);

// Group by year for the year headings
const byYear = sorted.reduce<Record<number, typeof sorted>>((acc, p) => {
  (acc[p.data.year] ||= []).push(p);
  return acc;
}, {});

const counts = {
  all: pubs.length,
  conference: pubs.filter((p) => p.data.type === 'conference').length,
  tutorial:   pubs.filter((p) => p.data.type === 'tutorial').length,
  preprint:   pubs.filter((p) => p.data.type === 'preprint').length,
  journal:    pubs.filter((p) => p.data.type === 'journal').length,
};
---

<BaseLayout
  title="Publications — Lenora Gray"
  description="Peer-reviewed publications, tutorials, and preprints by Lenora Gray."
  current="publications"
>
  <div class="pubs-intro">
    <h1>Publications</h1>
    <p class="lead">
      Peer-reviewed work and preprints, primarily on information retrieval, technology-assisted review, and applied machine learning in legal settings.
    </p>
    <div class="meta">
      <span id="pub-count">{counts.all}</span> entries · BibTeX available · <a href="https://scholar.google.com/citations?user=HYfXV94AAAAJ&hl=en&oi=ao">Google Scholar</a>
    </div>
  </div>

  <!-- Filter chips -->
  <div class="pub-controls" role="toolbar" aria-label="Filter publications by type">
    <span class="label">Filter</span>
    <button class="chip" data-filter="all" aria-pressed="true">All <span class="count">{counts.all}</span></button>
    {counts.conference > 0 && <button class="chip" data-filter="conference" aria-pressed="false">Conference <span class="count">{counts.conference}</span></button>}
    {counts.tutorial > 0   && <button class="chip" data-filter="tutorial"   aria-pressed="false">Tutorial <span class="count">{counts.tutorial}</span></button>}
    {counts.preprint > 0   && <button class="chip" data-filter="preprint"   aria-pressed="false">Preprint <span class="count">{counts.preprint}</span></button>}
    {counts.journal > 0    && <button class="chip" data-filter="journal"    aria-pressed="false">Journal <span class="count">{counts.journal}</span></button>}
  </div>

  {Object.entries(byYear)
    .sort(([a], [b]) => Number(b) - Number(a))
    .map(([year, entries]) => (
      <>
        <h3 class="year-head">{year}</h3>
        {entries.map((p) => <PublicationCard pub={p} />)}
      </>
    ))}
</BaseLayout>

<script>
  // Filter chip logic — vanilla JS, runs client-side
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]');
  const entries = document.querySelectorAll<HTMLElement>('article.entry[data-type]');
  const yearHeads = document.querySelectorAll<HTMLElement>('.year-head');
  const countEl = document.getElementById('pub-count');

  function apply(filter: string) {
    let shown = 0;
    entries.forEach((e) => {
      const match = filter === 'all' || e.dataset.type === filter;
      e.hidden = !match;
      if (match) shown++;
    });
    yearHeads.forEach((h) => {
      let n = h.nextElementSibling;
      let any = false;
      while (n && !n.classList.contains('year-head')) {
        if (n.matches('article.entry') && !(n as HTMLElement).hidden) { any = true; break; }
        n = n.nextElementSibling;
      }
      h.hidden = !any;
    });
    if (countEl) countEl.textContent = String(shown);
  }

  chips.forEach((c) => {
    c.addEventListener('click', () => {
      chips.forEach((x) => x.setAttribute('aria-pressed', x === c ? 'true' : 'false'));
      apply(c.dataset.filter!);
    });
  });
</script>

<style>
  .pubs-intro { max-width: 58ch; margin: 0 0 32px; }
  .pubs-intro h1 { font-size: clamp(36px, 4.5vw, 48px); margin: 0 0 24px; }
  .pubs-intro .lead {
    font-size: 19px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }
  .pubs-intro .meta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11.5px;
    color: var(--text-muted);
    margin-top: 14px;
    letter-spacing: 0.04em;
  }
  .pubs-intro .meta a {
    color: var(--accent);
    border-bottom: 0.5px solid currentColor;
    padding-bottom: 1px;
  }

  .pub-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 8px 0 28px;
    align-items: center;
  }
  .pub-controls .label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-right: 6px;
  }
  .chip {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--text);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    padding: 5px 11px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .chip:hover { border-color: var(--sand); }
  .chip[aria-pressed="true"] {
    background: var(--forest);
    color: var(--cream);
    border-color: var(--forest);
  }
  .chip .count { opacity: 0.65; margin-left: 6px; font-variant-numeric: tabular-nums; }
</style>
