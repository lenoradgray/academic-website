---
import BaseLayout from '../layouts/BaseLayout.astro';

const FORM_ENDPOINT = 'https://formspree.io/f/xojbrndq';
const MESSAGE_MAX = 2000;
---

<BaseLayout
  title="Contact — Lenora Gray"
  description="Get in touch with Lenora Gray for talks, teaching engagements, or collaboration."
  current="contact"

  <div class="contact-intro">
    <h1>Contact</h1>
    <p class="lead">
      The form below is the fastest way to reach me — for collaborations, invited talks, teaching engagements, or to ask about the research. I usually reply within a few days.
    </p>
  </div>

  <form
    class="contact-form"
    id="contact-form"
    action={FORM_ENDPOINT}
    method="POST"
    novalidate
  >
    <div class="form-head">
      <h2>Send a message</h2>
      <p>Including the audience, format, and date range for talk invitations helps me get back with a useful answer quickly.</p>
    </div>

    <div class="form-grid">
      <div class="form-field">
        <label for="cf-name">Your name</label>
        <input
          id="cf-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          aria-describedby="err-name"
        />
        <span class="form-error" id="err-name" aria-live="polite"></span>
      </div>

      <div class="form-field">
        <label for="cf-email">Your email</label>
        <input
          id="cf-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          aria-describedby="err-email"
        />
        <span class="form-error" id="err-email" aria-live="polite"></span>
      </div>

      <div class="form-field full">
        <label for="cf-subject">Subject</label>
        <input
          id="cf-subject"
          name="subject"
          type="text"
          required
          placeholder="A short summary"
          aria-describedby="err-subject"
        />
        <span class="form-error" id="err-subject" aria-live="polite"></span>
      </div>

      <div class="form-field full">
        <label for="cf-message">
          <span>Message</span>
          <span class="form-counter" id="cf-counter" aria-hidden="true">0 / {MESSAGE_MAX}</span>
        </label>
        <textarea
          id="cf-message"
          name="message"
          rows="6"
          required
          maxlength={MESSAGE_MAX}
          placeholder="What's on your mind?"
          aria-describedby="err-message"
        ></textarea>
        <span class="form-error" id="err-message" aria-live="polite"></span>
      </div>

      {/* Honeypot — hidden from humans + screen readers, visible to naive bots */}
      <div class="hp-wrap" aria-hidden="true">
        <label for="cf-website">Website (leave blank)</label>
        <input
          id="cf-website"
          name="_gotcha"
          type="text"
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      {/* Timestamp — populated by JS on render */}
      <input type="hidden" name="_ts" id="cf-ts" value="" />
    </div>

    <div class="form-actions">
      <button type="submit" class="form-submit" id="cf-submit">
        <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2 8h11M9 4l4 4-4 4" /></svg>
        <span class="form-submit-label">Send message</span>
      </button>
      <span class="form-hint">Replies usually within a few days.</span>
    </div>

    <div class="form-status" id="cf-status" role="status" aria-live="polite"></div>
  </form>

  <h2 class="elsewhere-h">Elsewhere</h2>
  <div class="contact-grid">
    <div class="channel">
      <span class="key">ORCID</span>
      <a class="value" href="https://orcid.org/0009-0008-4312-8780" target="_blank" rel="noopener">0009-0008-4312-8780</a>
      <span class="hint">Researcher identifier.</span>
    </div>
    <div class="channel">
      <span class="key">Google Scholar</span>
      <a class="value" href="https://scholar.google.com/citations?user=HYfXV94AAAAJ&hl=en&oi=ao">scholar.google.com/lenoragray</a>
      <span class="hint">Citations, papers, and metrics.</span>
    </div>
    <div class="channel">
      <span class="key">GitHub</span>
      <a class="value" href="https://github.com/lenoradgray">github.com/lenoradgray</a>
      <span class="hint">Reproductions, notebooks, and tutorials.</span>
    </div>
    <div class="channel">
      <span class="key">LinkedIn</span>
      <a class="value" href="https://www.linkedin.com/in/lenorag/">linkedin.com/in/lenoragray</a>
      <span class="hint">Professional history and updates.</span>
    </div>
  </div>
</BaseLayout>

<script>
  (function () {
    const form    = document.getElementById('contact-form');
    const status  = document.getElementById('cf-status');
    const submit  = document.getElementById('cf-submit');
    const tsField = document.getElementById('cf-ts');
    const message = document.getElementById('cf-message');
    const counter = document.getElementById('cf-counter');
    if (!form || !status || !submit || !tsField) return;

    // 1. Stamp render time (timestamp check)
    const renderedAt = Date.now();
    tsField.value = String(renderedAt);

    // 2. Live character counter
    const MAX = Number((message && message.getAttribute('maxlength')) || 2000);
    function updateCounter() {
      if (!message || !counter) return;
      const n = message.value.length;
      counter.textContent = n + ' / ' + MAX;
      counter.classList.toggle('near-limit', n > MAX * 0.9);
    }
    if (message) message.addEventListener('input', updateCounter);

    // 3. Per-field validation
    const FIELDS = ['name', 'email', 'subject', 'message'];
    const EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
    function errEl(k) { return document.getElementById('err-' + k); }
    function inEl(k)  { return form.querySelector('[name="' + k + '"]'); }

    function setError(k, msg) {
      const el = inEl(k); const err = errEl(k);
      if (el)  { el.setAttribute('aria-invalid', 'true'); el.classList.add('is-invalid'); }
      if (err) err.textContent = msg;
    }
    function clearError(k) {
      const el = inEl(k); const err = errEl(k);
      if (el)  { el.removeAttribute('aria-invalid'); el.classList.remove('is-invalid'); }
      if (err) err.textContent = '';
    }
    function validate() {
      let ok = true;
      function get(k) { const el = inEl(k); return (el && el.value ? el.value : '').trim(); }
      if (!get('name'))    { setError('name',    'Please enter your name.');     ok = false; } else clearError('name');
      if (!get('email'))   { setError('email',   'Please enter your email.');    ok = false; }
      else if (!EMAIL_RE.test(get('email'))) { setError('email', 'That email doesn\u2019t look right.'); ok = false; }
      else clearError('email');
      if (!get('subject')) { setError('subject', 'Please add a short subject.'); ok = false; } else clearError('subject');
      if (!get('message')) { setError('message', 'Please include a message.');   ok = false; } else clearError('message');
      return ok;
    }
    FIELDS.forEach(function (k) {
      const el = inEl(k);
      if (!el) return;
      el.addEventListener('input', function () {
        if (el.getAttribute('aria-invalid') === 'true') clearError(k);
      });
    });

    // 4. Status messages
    function showSuccess() {
      status.className = 'form-status is-success';
      status.textContent = 'Thanks \u2014 your message is on its way. I\u2019ll reply soon.';
      form.reset();
      tsField.value = String(Date.now());
      updateCounter();
    }
    function showError(msg) {
      status.className = 'form-status is-error';
      status.textContent = msg;
    }

    // 5. Submit
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      status.className = 'form-status';
      status.textContent = '';

      // Spam check A: honeypot
      const honeyEl = form.querySelector('[name="_gotcha"]');
      const honey = ((honeyEl && honeyEl.value) || '').trim();
      // Spam check B: timestamp
      const elapsed = Date.now() - renderedAt;
      if (honey || elapsed < 3000) {
        showSuccess(); // fail silently
        return;
      }

      if (!validate()) {
        const first = form.querySelector('[aria-invalid="true"]');
        if (first && typeof first.focus === 'function') first.focus();
        return;
      }

      // Loading state
      submit.disabled = true;
      submit.classList.add('is-loading');
      const labelEl = submit.querySelector('.form-submit-label');
      const prevLabel = labelEl ? labelEl.textContent : 'Send message';
      if (labelEl) labelEl.textContent = 'Sending\u2026';

      try {
        const fd = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: fd,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          showSuccess();
        } else {
          let detail = '';
          try {
            const data = await res.json();
            if (data && Array.isArray(data.errors) && data.errors[0] && data.errors[0].message) {
              detail = ' \u2014 ' + data.errors[0].message;
            }
          } catch (_) {}
          showError('Something went wrong sending your message' + detail + '. Please try again, or reach out via the channels below.');
        }
      } catch (err) {
        showError('Network error. Please check your connection and try again.');
      } finally {
        submit.disabled = false;
        submit.classList.remove('is-loading');
        if (labelEl) labelEl.textContent = prevLabel;
      }
    });

    updateCounter();
  })();
</script>

<style>
  h1 { font-size: clamp(36px, 4.5vw, 48px); margin: 0 0 24px; }
  .contact-intro { max-width: 58ch; margin-bottom: 8px; }
  .contact-intro .lead {
    font-size: 19px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  .contact-form {
    margin-top: 64px;
    padding: 36px 0 0;
    border-top: 0.5px solid var(--border);
  }
  .form-head { margin-bottom: 28px; }
  .form-head h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(22px, 2.6vw, 28px);
    color: var(--heading);
    margin: 0 0 10px;
  }
  .form-head p {
    font-size: 14.5px;
    color: var(--text-muted);
    max-width: 58ch;
    margin: 0;
    line-height: 1.55;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 32px;
    max-width: 720px;
  }
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-field.full { grid-column: 1 / -1; }
  .form-field label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .form-field input,
  .form-field textarea {
    appearance: none;
    background: transparent;
    border: 0;
    border-bottom: 0.5px solid var(--sand);
    padding: 8px 0;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: var(--text);
    line-height: 1.5;
    width: 100%;
    border-radius: 0;
    transition: border-color 0.15s;
  }
  .form-field textarea { resize: vertical; min-height: 120px; }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--sand);
    font-style: italic;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    border-bottom-color: var(--accent);
    outline: none;
  }
  .form-field input.is-invalid,
  .form-field textarea.is-invalid {
    border-bottom-color: var(--accent);
    border-bottom-width: 1px;
  }
  .form-field input.is-invalid:focus,
  .form-field textarea.is-invalid:focus {
    border-bottom-color: var(--accent);
  }

  .form-error {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--accent);
    min-height: 14px;
    margin-top: 2px;
  }

  .form-counter {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--text-muted);
  }
  .form-counter.near-limit { color: var(--accent); }

  /* Honeypot — visually + semantically hidden, but not display:none */
  .hp-wrap {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .form-actions {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .form-submit {
    appearance: none;
    border: 0;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: var(--forest);
    color: var(--cream);
    border-radius: 8px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s, opacity 0.15s;
  }
  .form-submit:hover { background: #234035; }
  .form-submit:disabled,
  .form-submit.is-loading {
    cursor: progress;
    opacity: 0.7;
  }
  .form-submit.is-loading svg {
    animation: cf-spin 1.1s linear infinite;
    transform-origin: center;
  }
  @keyframes cf-spin { to { transform: rotate(360deg); } }
  .form-submit svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.5; }
  .form-hint {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .form-status {
    margin-top: 22px;
    padding: 14px 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12.5px;
    letter-spacing: 0.02em;
    border-radius: 6px;
    border-left: 2px solid transparent;
    background: transparent;
    color: var(--heading);
    min-height: 0;
    display: none;
  }
  .form-status.is-success {
    display: block;
    background: rgba(45, 74, 62, 0.06);
    border-left-color: var(--forest);
    color: var(--heading);
  }
  .form-status.is-error {
    display: block;
    background: rgba(181, 85, 45, 0.06);
    border-left-color: var(--accent);
    color: var(--accent);
  }

  .elsewhere-h {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 22px;
    color: var(--heading);
    margin: 80px 0 4px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px 48px;
    margin-top: 36px;
  }
  .channel {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 22px 0;
    border-top: 0.5px solid var(--border);
  }
  .channel .key {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .channel .value {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--heading);
    line-height: 1.3;
    text-decoration: none;
    word-break: break-word;
    border-bottom: 0.5px solid transparent;
    width: fit-content;
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  a.value:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .channel .hint { font-size: 13px; color: var(--text-muted); margin-top: 2px; }

  @media (max-width: 640px) {
    .form-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>